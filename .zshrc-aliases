# ---- 📁 eza (ls con iconos) ----
alias ls="eza --icons=auto --color=auto --group-directories-first"
alias ll="eza --icons=auto --color=auto --group-directories-first -la"
alias la="eza --icons=auto --color=auto --group-directories-first -a"
alias lt="eza --icons=auto --color=auto --group-directories-first -T --level=3"
alias tree="eza --icons=auto --color=auto --group-directories-first -T"
alias l1="eza --icons=auto --color=auto --group-directories-first -1"

# ---- 📦 nala (apt con barras de progreso) ----
alias apt="nala"
alias apti="nala install"
alias aptr="nala remove"
alias aptp="nala purge"
alias apts="nala search"
alias aptu="nala update"
alias aptug="nala upgrade"
alias aptsu="nala show"

# ---- 🔍 fd (find) ----
alias fd="fdfind"

# ---- 📈 progress bars ----
alias wget="wget -q --show-progress"
alias curlp="curl -o"

# ---- 📊 monitorear operaciones ----
alias cpv="progress -m"
alias monitor-cp="watch -n 1 'progress 2>/dev/null || echo sin operaciones'"

# ---- 🌐 http + doggo ----
alias http="http --pretty=all"
alias dig="doggo"

# ---- 🖥️ tmux ----
alias tmux="tmux -2"
alias tnew="tmux new -s"
alias tls="tmux ls"
alias ta="tmux attach -t"

# ---- 🧹 utilidades ----
alias df="df -h"
alias du="du -h"
alias free="free -h"
alias cat="batcat --paging=never 2>/dev/null || cat"
alias ip="ip -c"
alias rm="trash"
alias ps="procs"
alias benchmark="hyperfine"
